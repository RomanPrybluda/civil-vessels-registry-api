generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Manufacturer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  country   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mainEngineRecords      VesselMainEngine[]
  auxiliaryEngineRecords VesselAuxiliaryEngine[]
  shaftGeneratorRecords  VesselShaftGenerator[]
  vessels                Vessel[]
}

model ClassificationSociety {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  shortName String   @unique
  country   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vessels Vessel[]
}

model Shipbuilder {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  country   String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vessels Vessel[]
}

model VesselType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vessels Vessel[]
}

model Vessel {
  id        String @id @default(uuid()) @db.Uuid
  name      String
  imoNumber String @unique

  length  Decimal  @db.Decimal(10, 2)
  breadth Decimal  @db.Decimal(10, 2)
  depth   Decimal? @db.Decimal(10, 2)
  draft   Decimal? @db.Decimal(10, 2)

  deadweight   Int?
  grossTonnage Int?
  iceClass     String?
  builtYear    Int

  vesselTypeId             String                 @db.Uuid
  vesselType               VesselType             @relation(fields: [vesselTypeId], references: [id])
  classificationSocietyId String?                 @db.Uuid
  classificationSociety   ClassificationSociety? @relation(fields: [classificationSocietyId], references: [id])
  manufacturerId          String?                 @db.Uuid
  manufacturer            Manufacturer?           @relation(fields: [manufacturerId], references: [id])
  shipbuilderId           String?                 @db.Uuid
  shipbuilder             Shipbuilder?            @relation(fields: [shipbuilderId], references: [id])
  mainEngines             VesselMainEngine[]
  auxiliaryEngines        VesselAuxiliaryEngine[]
  shaftGenerators         VesselShaftGenerator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([imoNumber])
  @@index([vesselTypeId])
  @@index([builtYear])
  @@index([manufacturerId])
  @@index([shipbuilderId])
}

model VesselMainEngine {
  id             String        @id @default(uuid()) @db.Uuid
  vesselId       String        @db.Uuid
  vessel         Vessel        @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  manufacturerId String?       @db.Uuid
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  model          String?
  quantity       Int
  powerKw        Int
  totalPowerKw   Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([vesselId])
  @@index([manufacturerId])
}

model VesselAuxiliaryEngine {
  id             String        @id @default(uuid()) @db.Uuid
  vesselId       String        @db.Uuid
  vessel         Vessel        @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  manufacturerId String?       @db.Uuid
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  model          String?
  quantity       Int
  powerKw        Int
  totalPowerKw   Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([vesselId])
  @@index([manufacturerId])
}

model VesselShaftGenerator {
  id             String        @id @default(uuid()) @db.Uuid
  vesselId       String        @db.Uuid
  vessel         Vessel        @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  manufacturerId String?       @db.Uuid
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  model          String?
  quantity       Int
  powerKw        Int
  totalPowerKw   Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([vesselId])
  @@index([manufacturerId])
}
